# =============================================================================
# CarbonTrace — environment template
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
#   cp .env.example .env   (Linux/macOS)
#   Copy-Item .env.example .env   (PowerShell)
# =============================================================================

# --- Runtime ----------------------------------------------------------------
ENVIRONMENT=development            # development | production

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=carbontrace
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=carbontrace
POSTGRES_PORT=5432
# Used by the backend container (host=postgres = the compose service name):
DATABASE_URL=postgresql+psycopg://carbontrace:change_me_strong_password@postgres:5432/carbontrace

# --- JWT / Auth -------------------------------------------------------------
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change_me_generate_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Elasticsearch ----------------------------------------------------------
ELASTICSEARCH_PORT=9200
# Heap is capped low on purpose to fit a single e2-medium VM:
ES_JAVA_OPTS=-Xms512m -Xmx512m

# --- Logstash ---------------------------------------------------------------
LOGSTASH_HTTP_PORT=8080
LS_JAVA_OPTS=-Xms256m -Xmx256m

# --- Kibana -----------------------------------------------------------------
KIBANA_PORT=5601

# --- External data APIs (the poller calls these every POLL_INTERVAL_MINUTES) -
ELECTRICITY_MAPS_API_KEY=your_electricity_maps_key
CARBON_INTERFACE_API_KEY=your_carbon_interface_key
OPENWEATHERMAP_API_KEY=your_openweathermap_key
POLL_INTERVAL_MINUTES=5

# --- Frontend ---------------------------------------------------------------
# Base URL the React app uses for API calls. Behind nginx this is just /api.
VITE_API_BASE_URL=/api

# --- Reverse proxy ----------------------------------------------------------
HTTP_PORT=80
# Comma-separated origins allowed by FastAPI CORS (dev convenience):
CORS_ORIGINS=http://localhost,http://localhost:5173
